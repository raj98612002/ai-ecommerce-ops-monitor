# ============================================================
.venv/
venv/
env/
dbt_venv/
*.venv

# ============================================================
# DBT
# ============================================================
dbt_project/target/
dbt_project/dbt_packages/
dbt_project/logs/
dbt_project/package-lock.yml

# ============================================================
# AIRFLOW
# ============================================================
airflow/logs/
airflow/plugins/
airflow.cfg
airflow.db
standalone_admin_password.txt

# ============================================================
